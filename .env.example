# === Database ===
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/tubeforge"

# === NextAuth ===
AUTH_SECRET="generate-a-secret-with-openssl-rand-base64-32"

# === Google OAuth ===
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# === Stripe (billing) ===
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_PRO=""
STRIPE_PRICE_STUDIO=""

# === AI APIs (optional — features degrade gracefully without these) ===
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
RUNWAY_API_KEY=""

# === App ===
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# === Analytics (optional — leave empty to disable) ===
# Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=""
# PostHog project API key
NEXT_PUBLIC_POSTHOG_KEY=""
# PostHog API host (defaults to https://us.i.posthog.com if omitted)
# NEXT_PUBLIC_POSTHOG_HOST=""

# === Feature flags (optional, comma-separated) ===
# NEXT_PUBLIC_FLAGS="aiVideoGeneration,aiThumbnails,aiMetadata,teamCollaboration,advancedAnalytics"

# YouTube API (for analytics features)
YOUTUBE_API_KEY="your-youtube-api-key"

# Video download backends
YT_DLP_API_URL="https://your-yt-dlp-instance.com"
COBALT_API_URL="https://your-cobalt-instance.com"

# Email (SMTP)
SMTP_URL="smtp://user:pass@smtp.example.com:587"
EMAIL_FROM="noreply@tubeforge.co"
