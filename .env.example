# ============================================================
# TubeForge — Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.
# Variables marked [REQUIRED] will crash the app on startup if missing.
# Variables marked [OPTIONAL] degrade gracefully when absent.
# ============================================================

# === Database [REQUIRED] ===
# PostgreSQL connection string used by Prisma
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/tubeforge"

# === Auth — Auth.js v5 (NextAuth) [REQUIRED] ===
# Generate with: openssl rand -base64 32
AUTH_SECRET="generate-a-secret-with-openssl-rand-base64-32"

# Google OAuth credentials — https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# NOTE: Do NOT set AUTH_URL or NEXTAUTH_URL — the app explicitly deletes them
# at runtime to avoid PKCE cookie domain mismatches. Auth.js auto-detects the
# host when trustHost:true is configured.

# === Stripe — Billing [REQUIRED in production] ===
# Get keys from https://dashboard.stripe.com/apikeys
# Use sk_test_xxx / pk_test_xxx for development, sk_live_xxx / pk_live_xxx for production
STRIPE_SECRET_KEY="sk_test_xxx"

# Webhook signing secret — https://dashboard.stripe.com/webhooks
# Required in production; optional in dev (skipped gracefully)
STRIPE_WEBHOOK_SECRET="whsec_xxx"

# Price IDs or Product IDs for the two paid plans.
# Accepts both price_xxx (exact price) and prod_xxx (auto-resolves default price).
# Required in production; optional in dev.
STRIPE_PRICE_PRO="price_xxx"
STRIPE_PRICE_STUDIO="price_xxx"

# Annual price IDs (optional — falls back to monthly prices if not set)
STRIPE_PRICE_PRO_ANNUAL="price_xxx"
STRIPE_PRICE_STUDIO_ANNUAL="price_xxx"

# === App URL [REQUIRED] ===
# Canonical URL of the running app (used in checkout redirects, emails, sitemap, etc.)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# === AI APIs [OPTIONAL] ===
# Features degrade gracefully without these
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
RUNWAY_API_KEY=""

# === YouTube / Video Download [OPTIONAL] ===
# YouTube Data API v3 key — used for analytics features
YOUTUBE_API_KEY=""

# Self-hosted yt-dlp API instance URL
YT_DLP_API_URL=""

# Cobalt API instance URL — primary download backend
COBALT_API_URL=""

# === Email — SMTP [OPTIONAL] ===
# Traditional SMTP transport for transactional emails
SMTP_URL="smtp://user:pass@smtp.example.com:587"
EMAIL_FROM="noreply@tubeforge.co"

# === Email — Resend [OPTIONAL but recommended] ===
# Resend is the primary email provider for transactional emails (welcome,
# password reset, billing receipts, etc.). Without it, emails are silently skipped.
#
# Setup:
#   1. Sign up at https://resend.com (free tier: 3,000 emails/month)
#   2. Add & verify your domain (tubeforge.co) — Resend will give you DNS records
#   3. Add SPF & DKIM DNS records at your registrar (GoDaddy)
#   4. Create an API key at https://resend.com/api-keys
#   5. Paste the key below
#
# Without this key the app runs fine, but no emails will be sent.
RESEND_API_KEY=""

# === VPN / WireGuard [OPTIONAL] ===
# Only needed if VPN feature is enabled for paid users
# 32-byte hex key for encrypting WireGuard configs at rest
VPN_ENCRYPTION_KEY=""
# WireGuard server public key
VPN_SERVER_PUBLIC_KEY=""
# WireGuard server endpoint (ip:port)
VPN_SERVER_ENDPOINT="57.128.254.111:51820"

# === Analytics [OPTIONAL] ===
# Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=""
# PostHog project API key
NEXT_PUBLIC_POSTHOG_KEY=""
# PostHog API host (defaults to https://us.i.posthog.com if omitted)
# NEXT_PUBLIC_POSTHOG_HOST=""

# === Redis — Upstash [OPTIONAL] ===
# Used for cross-instance rate limiting. Falls back to in-memory if not set.
# Create a free database at https://console.upstash.com
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# === Web Push — VAPID [OPTIONAL] ===
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""

# === Error Monitoring — Sentry [OPTIONAL] ===
# Client-side DSN — leave empty to disable Sentry entirely.
# To enable: create a Next.js project at https://sentry.io, copy the DSN
# (looks like https://xxx@xxx.ingest.sentry.io/xxx), and paste it here.
# Sentry is fully configured — client, server, and edge configs read this var.
# The SDK is disabled at runtime when the DSN is empty.
NEXT_PUBLIC_SENTRY_DSN=""

# === Feature Flags [OPTIONAL] ===
# Comma-separated list of features to enable beyond defaults.
# Known flags: aiVideoGeneration, aiThumbnails, aiMetadata,
#              teamCollaboration, advancedAnalytics, scheduledPublish
# NEXT_PUBLIC_FLAGS="aiVideoGeneration,aiThumbnails"

# === Promo Codes [OPTIONAL] ===
# JSON object overriding default promo codes for analytics tools.
# Example: PROMO_CODES='{"SHORTS2026":{"hours":24,"label":"24h access"}}'
# PROMO_CODES=''

# === Logging [OPTIONAL] ===
# Log level: debug | info | warn | error (default: info in prod, debug in dev)
# LOG_LEVEL="info"
